
{
  "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "outDir": "./dist",
      "rootDir": "./",
      "skipLibCheck": true,
      "esModuleInterop": true,
      "strict": true,

      /* Important for Render */
      "noEmit": false,
      "allowJs": true,
      "resolveJsonModule": true
    },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}